{% comment %}
  SNIPPET: BOTÓN DE COMPRA DIRECTA (PRODUCTO ÚNICO)
  Este snippet captura los datos del producto actual y los envía a WhatsApp.
{% endcomment %}

<div
  class="accelerated-checkout-block"
  ref="acceleratedCheckoutButtonContainer"
  {{ block.shopify_attributes }}
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
  {% unless can_add_to_cart %}
    hidden
  {% endunless %}
>
  {% if product != blank %}
    {% comment %}
      LÓGICA DINÁMICA:
      - Usamos {{ product.title }} para identificar el ítem.
      - El filtro 'money_without_trailing_zeros' elimina decimales innecesarios (.00) 
        para que el precio sea más legible en una pantalla de móvil pequeña.
    {% endcomment %}
    <a 
      href="https://wa.me/51984123788?text=Hola! Me interesa comprar el producto: {{ product.title }} que tiene un precio de {{ product.price | money_without_trailing_zeros }}" 
      class="button button--full-width button--primary"
      target="_blank"
      rel="noopener noreferrer"
      style="text-decoration: none; text-align: center; display: flex; align-items: center; justify-content: center; min-height: 45px; width: 100%;"
    >
      Comprar por WhatsApp
    </a>
  {% endif %}
</div>